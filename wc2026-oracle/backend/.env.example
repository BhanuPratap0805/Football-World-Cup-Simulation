# =============================================================================
# WC 2026 Oracle - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control (it's in .gitignore)
# =============================================================================

# Port number for the FastAPI server to listen on
PORT=8000

# CORS (Cross-Origin Resource Sharing) allowed origins
# Separate multiple origins with commas
# Format: http://localhost:5173 for local Vite dev, https://your-app.vercel.app for production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Cache TTL (Time To Live) in seconds
# Simulation results are cached for this duration to avoid re-running expensive Monte Carlo
# 3600 seconds = 1 hour
CACHE_TTL_SECONDS=3600
